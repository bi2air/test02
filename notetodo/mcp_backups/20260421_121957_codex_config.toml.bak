# Route all traffic through the self-hosted LLM hub
model          = "openai/gpt-5.3-codex"
model_provider = "llmhub"
model_reasoning_effort = "medium"

[model_providers.llmhub]
name     = "Internal LLM Hub"
base_url = "https://llmhub.tsengineering.io/v1"
wire_api = "responses"
env_key  = "OPENAI_API_KEY"

[projects."/Users/binh.nguyen2/working/postcall/affirm"]
trust_level = "trusted"

[projects."/Users/binh.nguyen2/Documents/New project"]
trust_level = "trusted"

[projects."/Users/binh.nguyen2/working/postcall"]
trust_level = "trusted"

[projects."/Users/binh.nguyen2/working/tsel/csv_code"]
trust_level = "trusted"

[mcp_servers.atlassian]
url = "https://mcp.atlassian.com/v1/mcp"

[mcp_servers.datadog]
url = "https://mcp.datadoghq.com/api/unstable/mcp-server/mcp?toolsets=all"

[mcp_servers.google-sheets]
command = "/Users/binh.nguyen2/miniconda3/envs/dev/bin/mcp-google-sheets"

[mcp_servers.google-sheets.env]
SERVICE_ACCOUNT_PATH = "/Users/binh.nguyen2/working/postcall/src/sa.json"

[mcp_servers.github]
url = "https://api.githubcopilot.com/mcp/"
bearer_token_env_var = "GITHUB_TOKEN"

[mcp_servers.google-sheets-sa]
command = "/Users/binh.nguyen2/miniconda3/envs/dev/bin/mcp-google-sheets"

[mcp_servers.google-sheets-sa.env]
SERVICE_ACCOUNT_PATH = "/Users/binh.nguyen2/working/postcall/src/sa.json"

[mcp_servers.google-sheets-user]
command = "/Users/binh.nguyen2/miniconda3/envs/dev/bin/mcp-google-sheets"

[mcp_servers.google-sheets-user.env]
CREDENTIALS_PATH = "/Users/binh.nguyen2/working/postcall/src/google_oauth_credentials.json"
TOKEN_PATH = "/Users/binh.nguyen2/working/postcall/src/google_oauth_token.json"
